# Database (for Docker Compose)
POSTGRES_DB=dental_clinic
POSTGRES_USER=dental
POSTGRES_PASSWORD=your_secure_password_here

# Backend (for local development without Docker)
# DATABASE_URL is auto-constructed in docker-compose.yml
DATABASE_URL=postgresql+asyncpg://dental:your_secure_password_here@localhost:5432/dental_clinic

# Security - Generate with: openssl rand -hex 32
SECRET_KEY=your_secret_key_here_use_openssl_rand_hex_32

# Independent secret for the public-budget verification cookie
# (see docs/adr/0006-budget-public-link-2-factor-auth.md).
# Generate with: openssl rand -hex 32. Falls back to SECRET_KEY in
# dev when unset; production deploys must set it explicitly.
BUDGET_PUBLIC_SECRET_KEY=

# Environment
ENVIRONMENT=development
ALLOWED_ORIGINS=http://localhost:3000

# Frontend
API_BASE_URL=http://localhost:8000
